# Solana RPC endpoint (mainnet)
RPC_URL=https://your-mainnet-rpc-url-here

# Keypair source — set exactly one of:
PRIVATE_KEY=your_base58_private_key_here
# KEYPAIR_FILE=/path/to/keypair.json

# Logging (optional, defaults to "info")
LOG_LEVEL=info

# Yellowstone gRPC (optional — slot stream)
# Use https:// prefix (e.g., https://fra.grpc.solinfra.dev). Host:port format without
# scheme (e.g., host:443) is NOT supported.
# YELLOWSTONE_ENDPOINT=https://your-yellowstone-endpoint-here
# YELLOWSTONE_GRPC_TOKEN=your_token_here

# Leader schedule and window detection (optional)
# Comma-separated list of known Jito-Solana validator identity pubkeys.
# If unset, all leaders are treated as non-Jito.
# JITO_VALIDATOR_KEYS=

# How often (in slot count) the heartbeat line is printed. Default 1 = every slot.
# LEADER_HEARTBEAT_INTERVAL=1

# Test transaction (optional, default false)
# When set to true, sends a 0-SOL self-transfer after startup to verify
# the Yellowstone transaction stream is working end-to-end.
# SEND_TEST_TX=false

# Tip data display (optional, default false)
# When set to true, fetches and prints Jito tip-floor percentiles and tip
# accounts on startup, then subscribes to the live tip stream.
# SHOW_TIP_DATA=false

# Jito tip-floor REST endpoint (optional)
# JITO_TIP_FLOOR_URL=https://bundles.jito.wtf/api/v1/bundles/tip_floor

# Jito tip stream WebSocket endpoint (optional)
# JITO_TIP_STREAM_URL=wss://bundles.jito.wtf/api/v1/bundles/tip_stream

# Jito Block Engine URL (optional)
# JITO_BLOCK_ENGINE_URL=https://mainnet.block-engine.jito.wtf

# REST backstop refresh interval in ms (optional, default 10000)
# Used when the WS feed is disconnected. Respects the Block Engine rate limit.
# JITO_TIP_REST_REFRESH_MS=10000

# Bundle submission (optional, default false)
# When set to true, constructs and submits a minimal self-transfer bundle
# to Jito's Block Engine with a hardcoded minimum tip.
# SEND_BUNDLE=false

# Bundle tip amount in lamports (optional, default 1000)
# The minimum tip Jito's protocol accepts. Will be replaced by agent decision
# in Phase 10.
# BUNDLE_TIP_LAMPORTS=1000

# Lifecycle log path (optional, defaults to src/lifecycle/log.jsonl)
# Override for testing or custom location. Can be absolute or relative.
# LIFECYCLE_LOG_PATH=lifecycle/log.jsonl

# Intentional blockhash expiry (optional, default false)
# When set to true, uses a finalized-commitment blockhash (already stale)
# to deterministically trigger an expired_blockhash failure for testing.
# INTENTIONAL_EXPIRY=false

# Max retry attempts on failure (optional, default 3, range 0-10)
# MAX_RETRIES=3

# Groq AI agent (Tip Intelligence)
# When GROQ_API_KEY is set, the bundle tip is decided by a live AI agent
# based on tip-floor percentiles, slot/leader context, and bundle metadata.
# If unset, the system falls back to BUNDLE_TIP_LAMPORTS (1000).
# GROQ_API_KEY=gsk_your_key_here
# GROQ_MODEL=llama-3.1-8b-instant
# GROQ_ENDPOINT=https://api.groq.com/openai/v1
# MAX_TIP_LAMPORTS=10000

# Volume run (optional)
# Number of sequential bundle submissions. When > 1, enters volume mode.
# VOLUME_COUNT=1

# Delay between volume submissions in milliseconds (optional, default 2000)
# VOLUME_INTERVAL_MS=2000

# Inject failure modes for testing. Comma-separated list: expiry, low_tip, compute_exceeded
# In volume mode (VOLUME_COUNT > 1), failure modes are cycled automatically.
# INJECT_FAILURE_MODE=
